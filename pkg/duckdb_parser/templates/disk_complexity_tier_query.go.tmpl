{{- /*
Disk Complexity Tier Query — Returns VM distribution by disk-complexity tier (4 levels).
These thresholds drive the complexity engine and must stay aligned with DiskSizeScores
in pkg/estimations/complexity/complexity.go.

Template Parameters:
  - ClusterFilter: filter by cluster name
*/ -}}
WITH vm_disk_totals AS (
    SELECT
        i."VM ID",
        COALESCE(SUM(d."Capacity MiB"), 0) / 1048576.0 AS total_disk_tb
    FROM vinfo i
    LEFT JOIN vdisk d ON i."VM ID" = d."VM ID"
    WHERE 1=1
    {{- if .ClusterFilter }} AND i."Cluster" = '{{.ClusterFilter}}'{{end}}
    GROUP BY i."VM ID"
)
SELECT
    CASE
        WHEN total_disk_tb < 10 THEN '0-10TiB'
        WHEN total_disk_tb < 20 THEN '10-20TiB'
        WHEN total_disk_tb < 50 THEN '20-50TiB'
        ELSE                         '50+TiB'
    END AS tier,
    COUNT(*) AS vm_count,
    ROUND(SUM(total_disk_tb), 2) AS total_size_tb
FROM vm_disk_totals
GROUP BY tier;
