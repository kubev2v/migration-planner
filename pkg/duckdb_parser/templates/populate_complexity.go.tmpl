{{- /*
Populate Complexity Template - Computes per-VM migration complexity from OS type and disk size.

Complexity levels (stored as INTEGER): 0=Unknown, 1=Easy, 2=Medium, 3=Hard, 4=WhiteGlove.
See pkg/estimations/complexity/README.md for score definitions and heuristics.

OS CASE clauses are injected via {{.OSCaseClauses}}, generated from OSDifficultyScores at
query-build time. Disk thresholds and the OS×disk combination matrix are hardcoded below.

No template parameters required (OSCaseClauses is pre-rendered before template execution).
*/ -}}
WITH vm_os AS (
    SELECT
        "VM ID",
        COALESCE(
            NULLIF("OS according to the VMware Tools", ''),
            NULLIF("OS according to the configuration file", ''),
            ''
        ) AS effective_os
    FROM vinfo
),
vm_os_level AS (
    SELECT
        "VM ID",
        CASE
{{.OSCaseClauses}}
            ELSE 'unsupported'
        END AS os_level
    FROM vm_os
),
vm_disk_totals AS (
    SELECT
        i."VM ID",
        COALESCE(SUM(d."Capacity MiB"), 0) / 1048576.0 AS total_disk_tb
    FROM vinfo i
    LEFT JOIN vdisk d ON i."VM ID" = d."VM ID"
    GROUP BY i."VM ID"
),
vm_disk_level AS (
    SELECT
        "VM ID",
        CASE
            WHEN total_disk_tb < 10 THEN 'easy'
            WHEN total_disk_tb < 20 THEN 'medium'
            WHEN total_disk_tb < 50 THEN 'hard'
            ELSE 'whiteglove'
        END AS disk_level
    FROM vm_disk_totals
),
vm_complexity AS (
    SELECT
        o."VM ID",
        CASE
{{.ComplexityMatrixClauses}}
            ELSE 0
        END AS complexity
    FROM vm_os_level o
    JOIN vm_disk_level dl ON o."VM ID" = dl."VM ID"
)
UPDATE vinfo
SET "OsDiskComplexity" = vc.complexity
FROM vm_complexity vc
WHERE vinfo."VM ID" = vc."VM ID";
